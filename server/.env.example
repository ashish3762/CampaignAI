# Stripe billing — leave blank in dev if you don't want to enable the paywall.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Where to send users after Checkout success/cancel.
PUBLIC_APP_URL=http://localhost:5173

# Supabase service-role key — SERVER ONLY. Never expose to the client.
# Used by the Stripe webhook to flip profiles.is_premium.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
